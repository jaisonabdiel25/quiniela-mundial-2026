# Conexión a PostgreSQL (docker-compose.yml levanta esta base local)
DATABASE_URL="postgresql://quiniela:quiniela@localhost:5435/quiniela"

# Secreto para firmar sesiones de Auth.js (genera uno con: npx auth secret)
AUTH_SECRET="cambiame"

# Credenciales del usuario administrador creado por el seed
ADMIN_SEED_EMAIL="admin@quiniela.local"
ADMIN_SEED_PASSWORD="admin123"
